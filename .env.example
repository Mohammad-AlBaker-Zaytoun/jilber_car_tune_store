# Copy this to .env (Prisma reads .env) / .env.local and fill in values

# ---------------------------------------------------------------------------
# Required: MSSQL connection (Prisma sqlserver connector)
# ---------------------------------------------------------------------------
# Local SQL Server via Docker:
#   docker run -e "ACCEPT_EULA=Y" -e "MSSQL_SA_PASSWORD=Your_strong_Pass123" \
#     -p 1433:1433 -d --name jilber-mssql mcr.microsoft.com/mssql/server:2022-latest
#   docker exec -it jilber-mssql /opt/mssql-tools18/bin/sqlcmd -S localhost \
#     -U sa -P 'Your_strong_Pass123' -C -Q "CREATE DATABASE jilber"
#
# encrypt=true + trustServerCertificate=true are required for the container's
# self-signed cert. For Azure SQL drop trustServerCertificate, keep encrypt=true.
DATABASE_URL="sqlserver://localhost:1433;database=jilber;user=sa;password=Your_strong_Pass123;encrypt=true;trustServerCertificate=true"

# Required: Secret key used to sign session JWTs (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-secret-key-here-minimum-32-chars

# SEO: Production URL used for canonical URLs, Open Graph, and sitemap
# Must NOT have a trailing slash
NEXT_PUBLIC_SITE_URL=https://example.com

# ---------------------------------------------------------------------------
# Optional: Email (Resend). If RESEND_API_KEY is unset, emails are no-ops.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
# Verified sender. Defaults to Resend's test sender if unset.
EMAIL_FROM="JILBER Performance <orders@yourdomain.com>"
# Where new-order / new-quote admin alerts are sent.
ADMIN_EMAIL=

# ---------------------------------------------------------------------------
# Optional: Product image uploads (VPS). When unset, files go to
# public/products/uploads (fine for local dev, but wiped on redeploy).
# In production point these at a PERSISTENT dir served by the reverse proxy.
# ---------------------------------------------------------------------------
# Absolute filesystem path, e.g. /var/lib/jilber/uploads
UPLOAD_DIR=
# URL prefix the reverse proxy serves UPLOAD_DIR from (no trailing slash)
UPLOAD_PUBLIC_PATH=/products/uploads

# ---------------------------------------------------------------------------
# One-time admin bootstrap (npm run db:seed:admin). Creates/promotes one admin.
# Unset these again after running.
# ---------------------------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME="Site Admin"
